<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="stackotterflow.pagekeeper.BookController"
  prefWidth="1000.0"
  prefHeight="700.0">

  <top>
    <VBox spacing="10.0" BorderPane.alignment="CENTER">
      <padding>
        <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
      </padding>

      <Label text="Add Book" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
      <Label text="Search Open Library, choose a result, then save it to your library."
        style="-fx-text-fill: #555555;"/>

      <HBox spacing="10.0">
        <TextField fx:id="searchField"
          promptText="Search by title, author, or ISBN"
          HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"/>
      </HBox>
    </VBox>
  </top>

  <center>
    <VBox spacing="12.0" BorderPane.alignment="CENTER">
      <padding>
        <Insets top="0.0" right="20.0" bottom="10.0" left="20.0"/>
      </padding>

      <Label text="Search Results" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

      <TableView fx:id="searchResultsTable" prefHeight="260.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="resultTitleColumn" text="Title" prefWidth="320.0"/>
          <TableColumn fx:id="resultAuthorColumn" text="Author" prefWidth="220.0"/>
          <TableColumn fx:id="resultYearColumn" text="Year" prefWidth="100.0"/>
          <TableColumn fx:id="resultIsbnColumn" text="ISBN" prefWidth="220.0"/>
        </columns>
      </TableView>
    </VBox>
  </center>

  <bottom>
    <VBox spacing="12.0" BorderPane.alignment="CENTER">
      <padding>
        <Insets top="10.0" right="20.0" bottom="20.0" left="20.0"/>
      </padding>

      <Separator/>

      <Label text="Selected Book" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

      <GridPane hgap="12.0" vgap="10.0">
        <columnConstraints>
          <ColumnConstraints minWidth="120.0"/>
          <ColumnConstraints hgrow="ALWAYS"/>
          <ColumnConstraints minWidth="120.0"/>
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="titleField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Author:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="authorField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="ISBN:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="isbnField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Total Pages:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="totalPagesField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statusComboBox" prefWidth="180.0"
          GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Current Page:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="currentPageField" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Summary:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="summaryField"
          prefRowCount="4"
          wrapText="true"
          GridPane.rowIndex="3"
          GridPane.columnIndex="1"
          GridPane.columnSpan="3"/>
      </GridPane>

      <HBox spacing="10.0">
        <Button text="Save to Library" onAction="#handleAddBook"/>
        <Button text="Clear" onAction="#handleClearForm"/>
        <Button text="Back" onAction="#handleBackToDashboard"/>
      </HBox>
    </VBox>
  </bottom>
</BorderPane>
