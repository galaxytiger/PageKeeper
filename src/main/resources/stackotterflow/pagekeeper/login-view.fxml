<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="400.0" prefWidth="571.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="stackotterflow.pagekeeper.LoginController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="69.0" layoutY="21.0" prefHeight="358.0" prefWidth="433.0" spacing="10.0">
         <children>
            <Label fx:id="welcome" alignment="CENTER" prefHeight="24.0" prefWidth="163.0" text="Welcome to PageKeeper!" />
            <Label fx:id="prompt" alignment="CENTER" prefHeight="17.0" prefWidth="145.0" text="Please Login/Register" />
            <TextField fx:id="usernameField" prefHeight="25.0" prefWidth="280.0" promptText="Username">
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
            </TextField>
            <PasswordField fx:id="passwordField" promptText="Password" />
            <Button mnemonicParsing="false" onAction="#handleLogin" text="Log In">
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleRegistration" text="Register New User" />
         </children>
         <padding>
            <Insets top="15.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
